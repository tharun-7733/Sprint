# ─────────────────────────────────────────────────
# Sprint 1 – Data Foundation  |  Environment Config
# Copy this file to .env and fill in your values.
# ─────────────────────────────────────────────────

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# SQLite database path (relative to project root)
DATABASE_URL=nifty100.db

# Directories
DATA_DIR=data/raw
PROCESSED_DIR=data/processed
OUTPUT_DIR=output

# Pipeline behaviour
# TRUNCATE_BEFORE_LOAD=true will wipe tables before each load (idempotent)
TRUNCATE_BEFORE_LOAD=true
